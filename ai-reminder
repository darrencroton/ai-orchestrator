class ToolSpec:
    def __init__(self, name: str, default_root: Path, command_names: tuple[str, ...]):
        self.name = name
        self.default_root = default_root
        self.command_names = command_names

    def extract_metadata(self, record: dict[str, Any]) -> tuple[str | None, str | None]:
        raise NotImplementedError

    def is_activity(self, record: dict[str, Any]) -> bool:
        raise NotImplementedError


class CodexSpec(ToolSpec):
    def __init__(self) -> None:
        super().__init__("codex", DEFAULT_CODEX_ROOT, ("codex",))

    def extract_metadata(self, record: dict[str, Any]) -> tuple[str | None, str | None]:
        record_type = record.get("type")
        payload = record.get("payload")
        if record_type == "session_meta" and isinstance(payload, dict):
            return payload.get("cwd"), payload.get("id")
        if record_type == "turn_context" and isinstance(payload, dict):
            return payload.get("cwd"), None
        return None, None

    def is_activity(self, record: dict[str, Any]) -> bool:
        record_type = record.get("type")
        payload = record.get("payload")
        if record_type in {"session_meta", "turn_context"}:
            return False
        if record_type == "event_msg" and isinstance(payload, dict):
            return payload.get("type") not in {"user_message"}
        if record_type == "response_item" and isinstance(payload, dict):
            payload_type = payload.get("type")
            if payload_type == "message":
                return payload.get("role") == "assistant"
            return True
        return False


class ClaudeSpec(ToolSpec):
    def __init__(self) -> None:
        super().__init__("claude", DEFAULT_CLAUDE_ROOT, ("claude",))

    def extract_metadata(self, record: dict[str, Any]) -> tuple[str | None, str | None]:
        cwd = record.get("cwd")
        session_id = record.get("sessionId") or record.get("session_id")
        return cwd, session_id

    def is_activity(self, record: dict[str, Any]) -> bool:
        record_type = record.get("type")
        if record_type in {"assistant", "queue-operation", "result"}:
            return True
        if record_type != "user":
            return False

        if record.get("toolUseResult") is not None:
            return True

        message = record.get("message")
        if not isinstance(message, dict):
            return False

        content = message.get("content")
        if isinstance(content, list):
            for item in content:
                if isinstance(item, dict) and item.get("type") == "tool_result":
                    return True
        return False


TOOL_SPECS: dict[str, ToolSpec] = {
    "codex": CodexSpec(),
    "claude": ClaudeSpec(),
}


def env_str(name: str, default: str) -> str:
    value = os.environ.get(name)
    return value if value is not None else default


def env_int(name: str, default: int) -> int:
    value = os.environ.get(name)
    if value is None:
        return default
    try:
        return int(value)
    except ValueError as exc:
        raise MonitorError(f"Environment variable {name} must be an integer.") from exc


def env_float(name: str, default: float) -> float:
    value = os.environ.get(name)
    if value is None:
        return default
    try:
        return float(value)
    except ValueError as exc:
        raise MonitorError(f"Environment variable {name} must be a number.") from exc


def default_state_dir() -> Path:
